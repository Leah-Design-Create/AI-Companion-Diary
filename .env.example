# 复制为 .env 后填写（勿将本项目的 .env 提交到 Git）

# LLM API（OpenAI 或兼容接口，如 DeepSeek、通义、Kimi 等）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 可选：RAG 语义检索（不填则仅用关键词检索）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 可选：知识库上传上限（过大易导致 MemoryError；字节=原始文件，字=提取后的正文长度）
# MAX_KNOWLEDGE_UPLOAD_BYTES=20971520
# MAX_KNOWLEDGE_TEXT_CHARS=2000000

# 可选：长期记忆（ChromaDB，存储历史对话向量）
# CHROMA_DIR=.chroma
# CHROMA_COLLECTION=chat_long_memory
# LONG_MEMORY_TOP_K=4
# LONG_MEMORY_MAX_CHARS=320

# 可选：通义 TTS（不填则用浏览器自带朗读）
# DASHSCOPE_API_KEY=sk-xxx
# DASHSCOPE_TTS_MODEL=qwen3-tts-flash
# DASHSCOPE_TTS_VOICE=芊悦

# 可选：心情画文生图（不填则跳过生图）
# IMAGE_GEN_MODEL=wanx-v1
# IMAGE_GEN_SIZE=512*512

# 可选：数据库路径、久未登录提醒天数
# DB_PATH=companion.db
# INACTIVE_DAYS_FOR_REMINDER=2

# 可选：评估模型（LLM-as-Judge 回复质量评分，支持 DeepSeek / OpenAI / Gemini 等）
# EVAL_API_KEY=sk-xxx
# EVAL_BASE_URL=https://api.deepseek.com
# EVAL_MODEL=deepseek-chat
